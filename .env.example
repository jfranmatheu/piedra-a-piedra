# Copia a web/.env.local para el frontend (solo URL + publishable).
# En Vercel/Netlify: Settings → Environment Variables.
# Docs: https://supabase.com/docs/guides/getting-started/api-keys
# Dashboard: Project Settings → API Keys

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Client (safe to expose): sb_publishable_...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Server only (Vercel/Netlify function invite-user): sb_secret_...
# NEVER prefix with VITE_ — never ship to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Public app URL (invite redirect)
APP_URL=http://localhost:5173

# --- Optional legacy JWT keys (still work until disabled in dashboard) ---
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
