# Copia a web/.env.local para desarrollo local
# En Vercel/Netlify configura las mismas keys en Project Settings → Environment Variables

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Solo para funciones serverless (invite) — NUNCA en el frontend
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# URL pública de la app (para redirects de invite)
APP_URL=http://localhost:5173
